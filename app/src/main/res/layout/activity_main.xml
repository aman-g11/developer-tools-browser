<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1a1a2e">

    <!-- Toolbar / URL Bar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#0d0d1a"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Forward"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_refresh"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Refresh"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />

        <EditText
            android:id="@+id/urlBar"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/url_bar_bg"
            android:hint="@string/url_hint"
            android:textColor="#e0e0e0"
            android:textColorHint="#666666"
            android:textSize="13sp"
            android:singleLine="true"
            android:imeOptions="actionGo"
            android:inputType="textUri"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:selectAllOnFocus="true" />

        <ImageButton
            android:id="@+id/btnDesktopToggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_desktop"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle Desktop Mode"
            android:tint="#4fc3f7"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/btnDevTools"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_devtools"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Toggle DevTools"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/btnTabs"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_tabs"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Tabs"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/btnMenu"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Menu"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Tab strip -->
    <HorizontalScrollView
        android:id="@+id/tabStrip"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="#12122a"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/tabContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />
    </HorizontalScrollView>

    <!-- Find in page bar -->
    <LinearLayout
        android:id="@+id/findBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="#252545"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/findInput"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:background="@drawable/url_bar_bg"
            android:hint="Find in page"
            android:textColor="#e0e0e0"
            android:textColorHint="#666666"
            android:textSize="13sp"
            android:singleLine="true"
            android:imeOptions="actionSearch"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <TextView
            android:id="@+id/findCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="12sp"
            android:paddingStart="8dp"
            android:paddingEnd="4dp" />

        <ImageButton
            android:id="@+id/findPrev"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/findNext"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_forward"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/findClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Close"
            android:tint="#aaaaaa"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Main content area: browser + devtools -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Browser container (holds the active tab's WebView) -->
        <FrameLayout
            android:id="@+id/browserContainer"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Draggable divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:background="#333355"
            android:visibility="gone" />

        <!-- DevTools WebView -->
        <WebView
            android:id="@+id/devtoolsWebView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
